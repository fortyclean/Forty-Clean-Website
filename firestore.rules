rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.admin == true
          || request.auth.token.role == "admin"
        );
    }

    function isSafeString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function isValidLeadSource() {
      return request.resource.data.source in ['contact_form', 'price_calculator', 'booking_system'];
    }

    function isValidLeadStatus() {
      return request.resource.data.status in ['new', 'contacted', 'completed'];
    }

    function isValidService() {
      return request.resource.data.service in ['cleaning', 'pest'];
    }

    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name', 'phone', 'trackingCode', 'service', 'details', 'price', 'timestamp', 'source', 'status'
      ])
      && isSafeString(request.resource.data.name, 100)
      && isSafeString(request.resource.data.phone, 20)
      && isSafeString(request.resource.data.trackingCode, 24)
      && isValidService()
      && request.resource.data.timestamp is string
      && isValidLeadSource()
      && isValidLeadStatus()
      && (!('details' in request.resource.data) || (request.resource.data.details is string && request.resource.data.details.size() <= 1000))
      && (!('price' in request.resource.data) || request.resource.data.price is number);

      allow read, delete: if isAdmin();

      allow update: if isAdmin()
      && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
      && isValidLeadStatus();
    }
    
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /customers/{customerId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name', 'phone', 'createdAt', 'userId', 'status'
      ])
      && isAdmin()
      && isSafeString(request.resource.data.name, 100)
      && isSafeString(request.resource.data.phone, 20)
      && (request.resource.data.createdAt is string || request.resource.data.createdAt is timestamp)
      && request.resource.data.userId is string
      && request.resource.data.userId == request.auth.uid
      && request.resource.data.status in ['new', 'contacted', 'completed'];

      allow read, delete: if isAdmin() && resource.data.userId == request.auth.uid;
      allow update: if isAdmin()
      && resource.data.userId == request.auth.uid
      && request.resource.data.keys().hasOnly(['name', 'phone', 'createdAt', 'userId', 'status'])
      && request.resource.data.userId == resource.data.userId
      && request.resource.data.name is string
      && request.resource.data.phone is string
      && request.resource.data.status in ['new', 'contacted', 'completed'];
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
