# Example environment variables for Forty Clean website
#
# Copy this file to `.env` and populate the values for your environment.
#
# Firebase client configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Base prices for services
VITE_CLEANING_BASE_PRICE=110
VITE_PEST_BASE_PRICE=25

# Firebase Admin configuration for server routes
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
